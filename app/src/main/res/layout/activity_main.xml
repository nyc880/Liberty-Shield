<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#071019"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="#071019" />

    <TextView
        android:id="@+id/top_header_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:letterSpacing="0.01"
        android:text="250 Years of Liberty , 250 Years of Privacy"
        android:textColor="#C9A85F"
        android:textSize="13sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="none" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <FrameLayout
            android:id="@+id/logo_image_shell"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="#071019">

            <ImageView
                android:id="@+id/top_map_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="false"
                android:scaleType="centerCrop"
                android:src="@drawable/map_background" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0B1118"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/encrypt_btn"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#11161D"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:rippleColor="#22D4AF37"
            app:strokeColor="#C9A85F"
            app:strokeWidth="1.2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:id="@+id/encrypt_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_lock_lock"
                    app:tint="#D4AF37" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="monospace"
                    android:text="ENCRYPT"
                    android:textColor="#E6C97A"
                    android:textSize="21sp"
                    android:textStyle="bold" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/decrypt_btn"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#11161D"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:rippleColor="#22D4AF37"
            app:strokeColor="#C9A85F"
            app:strokeWidth="1.2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:id="@+id/decrypt_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_partial_secure"
                    app:tint="#D4AF37" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="monospace"
                    android:text="DECRYPT"
                    android:textColor="#E6C97A"
                    android:textSize="21sp"
                    android:textStyle="bold" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/safe_delete_btn"
            android:layout_width="match_parent"
            android:layout_height="57dp"
            android:layout_marginTop="22dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#10151B"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:rippleColor="#22D4AF37"
            app:strokeColor="#C9A85F"
            app:strokeWidth="1.1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:id="@+id/delete_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="#D4AF37" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="monospace"
                    android:text="SAFE DELETE"
                    android:textColor="#E6C97A"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/safe_exit_btn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#B71C1C"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            app:rippleColor="#33FFFFFF">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="monospace"
                    android:text="safe exit"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="#0B1118" />

</LinearLayout>