<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />

    <application
        android:allowBackup="false"
        android:hasFragileUserData="false"
        android:largeHeap="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LOCK"
        tools:replace="android:allowBackup">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".TextEncryptionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".FileBrowserActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".FilePreviewActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".EncryptionSettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ProcessingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".DecryptionSettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SafeDeleteConfirmActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SafeDeleteActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>
</manifest>